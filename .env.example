# --- Site (production: set canonical URL; Vercel fills VERCEL_URL if unset) ---
SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Auth (required for sessions; use a long random string in production) ---
AUTH_SECRET=

# --- Database (Turso) ---
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Admin bootstrap login ---
ADMIN_EMAIL=
ADMIN_PIN=
ADMIN_NAME=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_API_VERSION=2026-02-25.clover

# --- Email (transactional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# --- Brevo (marketing contacts when email is present on lead forms) ---
BREVO_API_KEY=

# --- Cloudflare R2 (optional file uploads) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# --- Mapbox (optional address UI) ---
# NEXT_PUBLIC_MAPBOX_TOKEN=
